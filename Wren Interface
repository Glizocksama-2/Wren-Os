                {tasks.map(task => (
                  <div key={task._id} className={`task-card ${dragging === task._id ? "dragging" : ""}`}
                    draggable onDragStart={() => setDragging(task._id)} onDragEnd={() => { setDragging(null); setDragOver(null); }}
                    onClick={() => setSelectedTask(task)}>
                    <div className="task-card-title">{task.title}</div>
                    <div className="task-card-meta">
                      <span className={`badge badge-${task.priority}`}>{task.priority}</span>
                      {task.tags?.slice(0, 2).map(t => <span key={t} className="badge badge-tag">{t}</span>)}
                    </div>
                    <div className="task-card-footer">
                      <div className={`task-due ${isOverdue(task.dueDate) && task.status !== "done" ? "overdue" : ""}`}>
                        {task.dueDate ? `📅 ${fmtDate(task.dueDate)}` : ""}
                      </div>
                      <div style={{ display: "flex", gap: 5, alignItems: "center" }}>
                        {proj(task.projectId) && <span className="badge badge-tag" style={{ fontSize: 10 }}>{proj(task.projectId).name}</span>}
                        <span className={`badge badge-${task.source}`} style={{ fontSize: 10 }}>{task.source}</span>
                      </div>
                    </div>
                  </div>
                ))}
                <button className="btn btn-ghost btn-sm" style={{ width: "100%", justifyContent: "center", marginTop: 4, color: "var(--text3)" }} onClick={() => setShowCreate(col.id)}>+ Add task</button>
