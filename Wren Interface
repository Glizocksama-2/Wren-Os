        <div><div className="w-page-title">Projects</div><div className="w-page-sub">{projects.length} active workstreams</div></div>
        <button className="btn btn-primary" onClick={() => setShowCreate(true)}>+ New Project</button>
      </div>
      <div className="card-grid">
        {projects.map(p => {
          const total = taskCount(p._id), done = doneCount(p._id);
          const pct = total ? Math.round((done / total) * 100) : 0;
          return (
            <div key={p._id} className="w-card" onClick={() => setSelected(p._id)}>
              <div className="w-card-title">{p.name}</div>
              <div className="w-card-desc">{p.description || "No description"}</div>
              <div className="progress-bar" style={{ marginBottom: 10 }}><div className="progress-fill" style={{ width: pct + "%" }} /></div>
              <div className="w-card-footer">
                <span className={`badge badge-${p.status}`}>{p.status}</span>
                <span style={{ fontSize: 12, color: "var(--text3)" }}>{done}/{total} tasks · {pct}%</span>
              </div>
            </div>
          );
        })}
      </div>
      {showCreate && (
        <div className="modal-bg" onClick={() => setShowCreate(false)}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <div className="modal-title">New Project</div>
            <div className="fg"><label className="fg-label">Name *</label><input className="fg-input" placeholder="Project name" value={form.name} onChange={e => setForm({ ...form, name: e.target.value })} autoFocus /></div>
            <div className="fg"><label className="fg-label">Description</label><textarea className="fg-textarea" placeholder="What is this project about?" value={form.description} onChange={e => setForm({ ...form, description: e.target.value })} /></div>
            <div className="fg"><label className="fg-label">Status</label><select className="fg-select" value={form.status} onChange={e => setForm({ ...form, status: e.target.value })}><option value="active">Active</option><option value="archived">Archived</option></select></div>
            <div className="modal-actions">
              <button className="btn btn-ghost" onClick={() => setShowCreate(false)}>Cancel</button>
              <button className="btn btn-primary" disabled={!form.name.trim()} onClick={() => { dispatch({ type: "CREATE_PROJECT", payload: { ...form } }); setShowCreate(false); setForm({ name: "", description: "", status: "active" }); }}>Create Project</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── CONTENT QUEUE ──────────────────────────────────────────────────────── */
const CONTENT_STAGES = ["idea", "draft", "published"];
const PLATFORM_ICON = { twitter: "𝕏", linkedin: "in", blog: "✍️", other: "•" };

function ContentQueue({ state, dispatch }) {
  const [showCreate, setShowCreate] = useState(false);
  const [editing, setEditing] = useState(null);
  const [form, setForm] = useState({ title: "", platform: "twitter", status: "idea", hook: "", brief: "", draft: "", link: "", tags: [] });

  const items = state.contentItems.filter(c => c.workspaceId === WS_ID);

  return (
    <div className="w-page">
      <div className="w-page-hd">
        <div><div className="w-page-title">Content Queue</div><div className="w-page-sub">{items.length} items across all stages</div></div>
        <button className="btn btn-primary" onClick={() => { setForm({ title: "", platform: "twitter", status: "idea", hook: "", brief: "", draft: "", link: "", tags: [] }); setShowCreate(true); }}>+ New Idea</button>
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 14 }}>
        {CONTENT_STAGES.map(stage => {
          const stageItems = items.filter(c => c.status === stage);
          return (
            <div key={stage} className="k-col">
              <div className="k-col-hd">
                <div className="k-col-title"><span className={`k-col-dot ${stage === "idea" ? "dot-todo" : stage === "draft" ? "dot-in_progress" : "dot-done"}`} />{stage.charAt(0).toUpperCase() + stage.slice(1)}</div>
                <div className="k-col-count">{stageItems.length}</div>
              </div>
              <div className="k-body">
                {stageItems.length === 0 && <div className="k-empty">Nothing here yet</div>}
                {stageItems.map(item => (
                  <div key={item._id} className="task-card" onClick={() => { setEditing(item); setForm(item); setShowCreate(true); }}>
                    <div style={{ display: "flex", gap: 6, marginBottom: 6, alignItems: "center" }}>
                      <span style={{ fontSize: 13, fontWeight: 600, color: "var(--text3)" }}>{PLATFORM_ICON[item.platform]}</span>
                      <span className="badge badge-tag" style={{ fontSize: 10, textTransform: "capitalize" }}>{item.platform}</span>
                    </div>
                    <div className="task-card-title">{item.title}</div>
                    {item.hook && <div style={{ fontSize: 12, color: "var(--text3)", fontStyle: "italic", marginBottom: 6, lineHeight: 1.4 }}>"{item.hook}"</div>}
                    <div style={{ display: "flex", gap: 5, flexWrap: "wrap" }}>{item.tags?.slice(0, 2).map(t => <span key={t} className="badge badge-tag">{t}</span>)}</div>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>
      {showCreate && (
        <div className="modal-bg" onClick={() => { setShowCreate(false); setEditing(null); }}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <div className="modal-title">{editing ? "Edit Content" : "New Content Idea"}</div>
            <div className="fg"><label className="fg-label">Title *</label><input className="fg-input" placeholder="What's this piece about?" value={form.title} onChange={e => setForm({ ...form, title: e.target.value })} autoFocus /></div>
            <div className="fg-row">
              <div className="fg"><label className="fg-label">Platform</label><select className="fg-select" value={form.platform} onChange={e => setForm({ ...form, platform: e.target.value })}><option value="twitter">Twitter / X</option><option value="linkedin">LinkedIn</option><option value="blog">Blog</option><option value="other">Other</option></select></div>
              <div className="fg"><label className="fg-label">Status</label><select className="fg-select" value={form.status} onChange={e => setForm({ ...form, status: e.target.value })}><option value="idea">Idea</option><option value="draft">Draft</option><option value="published">Published</option></select></div>
            </div>
            <div className="fg"><label className="fg-label">Hook</label><input className="fg-input" placeholder="Opening line or angle" value={form.hook} onChange={e => setForm({ ...form, hook: e.target.value })} /></div>
            <div className="fg"><label className="fg-label">Brief / Notes</label><textarea className="fg-textarea" placeholder="Key points, outline, research notes…" value={form.brief} onChange={e => setForm({ ...form, brief: e.target.value })} /></div>
            {form.status === "published" && <div className="fg"><label className="fg-label">Published Link</label><input className="fg-input" placeholder="https://…" value={form.link} onChange={e => setForm({ ...form, link: e.target.value })} /></div>}
            <div className="fg"><label className="fg-label">Tags</label><TagInput value={form.tags} onChange={tags => setForm({ ...form, tags })} /></div>
            <div className="modal-actions">
              <button className="btn btn-ghost" onClick={() => { setShowCreate(false); setEditing(null); }}>Cancel</button>
              <button className="btn btn-primary" disabled={!form.title.trim()} onClick={() => {
                if (editing) dispatch({ type: "UPDATE_CONTENT", id: editing._id, payload: form });
                else dispatch({ type: "CREATE_CONTENT", payload: form });
                setShowCreate(false); setEditing(null);
              }}>{editing ? "Save Changes" : "Add to Queue"}</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── DOCUMENTS ──────────────────────────────────────────────────────────── */
function Documents({ state, dispatch }) {
  const [showCreate, setShowCreate] = useState(false);
  const [form, setForm] = useState({ title: "", kind: "url", url: "", body: "", tags: [] });
  const [view, setView] = useState(null);

  const docs = state.documents.filter(d => d.workspaceId === WS_ID);
  const KIND_ICON = { notion: "📄", url: "🔗", internal: "📝" };

  return (
    <div className="w-page">
      <div className="w-page-hd">
        <div><div className="w-page-title">Documents</div><div className="w-page-sub">Notion links, URLs, and internal notes</div></div>
        <button className="btn btn-primary" onClick={() => { setForm({ title: "", kind: "url", url: "", body: "", tags: [] }); setShowCreate(true); }}>+ Add Document</button>
      </div>
      <div className="w-table-wrap">
        <table className="w-table">
          <thead><tr><th>Title</th><th>Type</th><th>Tags</th><th>Updated</th></tr></thead>
          <tbody>
            {docs.length === 0 && <tr><td colSpan={4} style={{ textAlign: "center", color: "var(--text3)", padding: 32 }}>No documents yet</td></tr>}
            {docs.map(d => (
              <tr key={d._id} onClick={() => setView(d)}>
                <td><span style={{ marginRight: 6 }}>{KIND_ICON[d.kind]}</span><span style={{ fontWeight: 500 }}>{d.title}</span></td>
                <td><span className={`badge badge-${d.kind}`}>{d.kind}</span></td>
                <td><div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>{d.tags?.slice(0, 3).map(t => <span key={t} className="badge badge-tag">{t}</span>)}</div></td>
                <td style={{ color: "var(--text3)", fontSize: 12, fontFamily: "var(--font-mono)" }}>{fmtTime(d.updatedAt)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {view && (
        <>
          <div className="drawer-overlay" onClick={() => setView(null)} />
          <div className="drawer">
            <div className="drawer-hd">
              <div className="drawer-title">{view.title}</div>
              <button className="close-btn" onClick={() => setView(null)}>✕</button>
            </div>
            <div className="drawer-body">
              <div className="drawer-grid" style={{ marginBottom: 16 }}>
                <div className="drawer-field"><div className="drawer-field-label">Type</div><span className={`badge badge-${view.kind}`}>{view.kind}</span></div>
                <div className="drawer-field"><div className="drawer-field-label">Updated</div><div className="drawer-field-val">{fmtTime(view.updatedAt)}</div></div>
              </div>
              {view.url && <div style={{ marginBottom: 16 }}><a href={view.url} target="_blank" rel="noreferrer" className="drawer-link">🔗 Open link</a></div>}
              {view.body && <div className="drawer-desc" style={{ marginBottom: 16 }}>{view.body}</div>}
              {view.tags?.length > 0 && <div style={{ display: "flex", gap: 5, flexWrap: "wrap" }}>{view.tags.map(t => <span key={t} className="badge badge-tag">{t}</span>)}</div>}
            </div>
          </div>
        </>
      )}

      {showCreate && (
        <div className="modal-bg" onClick={() => setShowCreate(false)}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <div className="modal-title">Add Document</div>
            <div className="fg"><label className="fg-label">Title *</label><input className="fg-input" placeholder="Document name" value={form.title} onChange={e => setForm({ ...form, title: e.target.value })} autoFocus /></div>
            <div className="fg"><label className="fg-label">Type</label><select className="fg-select" value={form.kind} onChange={e => setForm({ ...form, kind: e.target.value })}><option value="notion">Notion</option><option value="url">URL</option><option value="internal">Internal Note</option></select></div>
            {(form.kind === "notion" || form.kind === "url") && <div className="fg"><label className="fg-label">URL</label><input className="fg-input" placeholder="https://…" value={form.url} onChange={e => setForm({ ...form, url: e.target.value })} /></div>}
            {form.kind === "internal" && <div className="fg"><label className="fg-label">Content</label><textarea className="fg-textarea" style={{ minHeight: 100 }} placeholder="Write your note…" value={form.body} onChange={e => setForm({ ...form, body: e.target.value })} /></div>}
            <div className="fg"><label className="fg-label">Tags</label><TagInput value={form.tags} onChange={tags => setForm({ ...form, tags })} /></div>
            <div className="modal-actions">
              <button className="btn btn-ghost" onClick={() => setShowCreate(false)}>Cancel</button>
              <button className="btn btn-primary" disabled={!form.title.trim()} onClick={() => { dispatch({ type: "CREATE_DOCUMENT", payload: form }); setShowCreate(false); }}>Add Document</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── ACTIVITY FEED ──────────────────────────────────────────────────────── */
function ActivityFeed({ state }) {
  const events = [...state.activityEvents].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
  return (
    <div className="w-page">
      <div className="w-page-hd">
        <div><div className="w-page-title">Activity</div><div className="w-page-sub">Global event log — newest first</div></div>
      </div>
      <div className="w-table-wrap" style={{ padding: "0 16px" }}>
        {events.length === 0 && <div className="empty-state"><div className="empty-state-icon">📭</div><div className="empty-state-text">No activity yet</div></div>}
        <div className="activity-list">
          {events.map((e, i) => (
            <div key={e._id} className="activity-item">
              <div className="activity-dot-wrap"><div className={`activity-dot ${i < 3 ? "fresh" : ""}`} /></div>
              <div className="activity-content">
                <div className="activity-text">{summarizeEvent(e, state)}</div>
                <div className="activity-time">{fmtTime(e.createdAt)}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

/* ─── AGENT API DOCS ─────────────────────────────────────────────────────── */
function AgentAPI({ toast, setToast }) {
  const copy = (text) => { navigator.clipboard.writeText(text); setToast("Copied!"); setTimeout(() => setToast(""), 2000); };
  const endpoints = [
    { method: "POST", path: "/api/agent/listTasks", desc: "List all tasks for workspace" },
    { method: "POST", path: "/api/agent/createTask", desc: "Create a new task" },
    { method: "POST", path: "/api/agent/updateTask", desc: "Update task fields" },
    { method: "POST", path: "/api/agent/moveTaskStatus", desc: "Move task + write activity event" },
    { method: "POST", path: "/api/agent/createContentIdea", desc: "Add to content queue" },
    { method: "POST", path: "/api/agent/updateContentItem", desc: "Update content item" },
    { method: "POST", path: "/api/agent/createDocumentLink", desc: "Add document or link" },
    { method: "POST", path: "/api/agent/attachDocumentToTask", desc: "Link document to task" },
    { method: "POST", path: "/api/agent/appendActivityEvent", desc: "Log a custom event" },
  ];

  return (
    <div className="w-page">
      <div className="w-page-hd">
        <div><div className="w-page-title">Agent API</div><div className="w-page-sub">HTTP endpoints for OpenClaw and external agents</div></div>
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 14, marginBottom: 24 }}>
        <div className="stat-card">
          <div className="w-agent-key-label" style={{ marginBottom: 8 }}>Agent API Key</div>
          <div className="api-key-box">{AGENT_KEY}</div>
          <button className="btn btn-secondary btn-sm" style={{ marginTop: 10 }} onClick={() => copy(AGENT_KEY)}>Copy Key</button>
        </div>
        <div className="stat-card">
          <div className="w-agent-key-label" style={{ marginBottom: 8 }}>Auth Header</div>
          <div className="api-key-box">Authorization: Bearer {AGENT_KEY.slice(0, 24)}…</div>
          <div style={{ marginTop: 10, fontSize: 12, color: "var(--text3)" }}>All requests require this header. 401 on failure.</div>
        </div>
      </div>

      <div style={{ marginBottom: 18 }}>
        <div className="w-agent-key-label" style={{ marginBottom: 10, fontSize: 11, fontWeight: 600, color: "var(--text3)", letterSpacing: ".06em", textTransform: "uppercase" }}>Response Shape</div>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
          <div><div style={{ fontSize: 11, color: "var(--text3)", marginBottom: 4 }}>Success</div><div className="api-key-box">{"{ \"ok\": true, \"data\": {} }"}</div></div>
          <div><div style={{ fontSize: 11, color: "var(--text3)", marginBottom: 4 }}>Error</div><div className="api-key-box">{"{ \"ok\": false, \"error\": { \"code\": \"\", \"message\": \"\" } }"}</div></div>
        </div>
      </div>

      <div className="w-table-wrap">
        <table className="w-table">
          <thead><tr><th>Method</th><th>Endpoint</th><th>Description</th><th></th></tr></thead>
          <tbody>
            {endpoints.map(ep => (
              <tr key={ep.path}>
                <td><span className="badge badge-in_progress" style={{ fontFamily: "var(--font-mono)", fontSize: 10 }}>{ep.method}</span></td>
                <td><span style={{ fontFamily: "var(--font-mono)", fontSize: 12, color: "var(--text)" }}>{ep.path}</span></td>
                <td style={{ color: "var(--text2)" }}>{ep.desc}</td>
                <td><button className="btn btn-ghost btn-sm" onClick={() => copy(ep.path)}>Copy</button></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div style={{ marginTop: 20, padding: 16, background: "var(--surface)", border: "1px solid var(--border)", borderRadius: "var(--r-lg)" }}>
        <div style={{ fontSize: 11, fontWeight: 600, color: "var(--text3)", letterSpacing: ".06em", textTransform: "uppercase", marginBottom: 10 }}>OpenClaw Integration — Add to your prompt</div>
        <div className="api-key-box" style={{ cursor: "pointer" }} onClick={() => copy(`openclaw config set agent.apiKey ${AGENT_KEY}\nopenclaw config set agent.apiBase https://wren-os.onrender.com`)}>
          {`openclaw config set agent.apiKey ${AGENT_KEY}\nopenclaw config set agent.apiBase https://wren-os.onrender.com`}
        </div>
        <div style={{ fontSize: 11, color: "var(--text3)", marginTop: 6 }}>Click to copy both commands</div>
      </div>
    </div>
  );
}

/* ─── SIDEBAR ────────────────────────────────────────────────────────────── */
const NAV = [
  { id: "dashboard", icon: "⊞", label: "Dashboard" },
  { id: "projects", icon: "◫", label: "Projects" },
  { id: "content", icon: "✦", label: "Content Queue" },
  { id: "documents", icon: "◻", label: "Documents" },
  { id: "activity", icon: "◎", label: "Activity" },
  { id: "api", icon: "⌁", label: "Agent API" },
];

/* ─── ROOT ───────────────────────────────────────────────────────────────── */
export default function WrenOS() {
  const [state, dispatch] = useReducer(reducer, SEED);
  const [page, setPage] = useState("dashboard");
  const [toast, setToast] = useState("");

  const projects = state.projects.filter(p => p.workspaceId === WS_ID);
  const taskCount = (nav) => {
    if (nav === "dashboard") return state.tasks.filter(t => t.status !== "done").length;
    if (nav === "content") return state.contentItems.filter(c => c.status !== "published").length;
    if (nav === "activity") return state.activityEvents.length;
    return null;
  };

  const copy = (text) => { navigator.clipboard.writeText(text); setToast("Copied!"); setTimeout(() => setToast(""), 2000); };

  return (
    <div className="w-layout">
      {/* Sidebar */}
      <aside className="w-sidebar">
        <div className="w-logo">
          <div className="w-logo-mark">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 3h4v4H3zM9 3h4v4H9zM3 9h4v4H3zM11 9v6M8 12h6" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
            </svg>
          </div>
          <div><div className="w-logo-name">Wren OS</div><div className="w-logo-sub">Agent Workspace</div></div>
        </div>
        <nav className="w-nav">
          <div className="w-nav-section">
            <div className="w-nav-label">Workspace</div>
            {NAV.map(item => (
              <div key={item.id} className={`w-nav-item ${page === item.id ? "active" : ""}`} onClick={() => setPage(item.id)}>
                <span className="w-nav-icon">{item.icon}</span>
                {item.label}
                {taskCount(item.id) ? <span className="w-nav-badge">{taskCount(item.id)}</span> : null}
              </div>
            ))}
          </div>
          <div className="w-nav-section">
            <div className="w-nav-label">Projects</div>
            {projects.filter(p => p.status === "active").map(p => (
              <div key={p._id} className="w-nav-item" onClick={() => setPage("projects")}>
                <span className="w-nav-icon" style={{ fontSize: 10 }}>●</span>
                <span style={{ overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{p.name}</span>
              </div>
            ))}
          </div>
        </nav>
        <div className="w-sidebar-footer">
          <div className="w-agent-key">
            <div className="w-agent-key-label">Agent Key</div>
            <div className="w-agent-key-val">{AGENT_KEY.slice(0, 28)}…</div>
            <button className="btn btn-ghost btn-sm" style={{ marginTop: 6, width: "100%", justifyContent: "center" }} onClick={() => copy(AGENT_KEY)}>Copy Key</button>
          </div>
        </div>
      </aside>

      {/* Main */}
      <main className="w-main">
        {page === "dashboard" && <Dashboard state={state} dispatch={dispatch} projects={projects} />}
        {page === "projects" && <Projects state={state} dispatch={dispatch} />}
        {page === "content" && <ContentQueue state={state} dispatch={dispatch} />}
        {page === "documents" && <Documents state={state} dispatch={dispatch} />}
        {page === "activity" && <ActivityFeed state={state} />}
        {page === "api" && <AgentAPI toast={toast} setToast={setToast} />}
      </main>

      <Toast msg={toast} />
    </div>
  );
}
