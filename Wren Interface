      )}
      {showCreate && (
        <CreateTaskModal projects={projects} defaultStatus={showCreate} onClose={() => setShowCreate(null)}
          onCreate={(payload) => dispatch({ type: "CREATE_TASK", payload })} />
      )}
    </div>
  );
}

