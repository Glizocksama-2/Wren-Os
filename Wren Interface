        <div className="stat-card"><div className="stat-val" style={{ color: "var(--accent)" }}>{done}</div><div className="stat-label">Done</div></div>
        <div className="stat-card"><div className="stat-val" style={{ color: overdue ? "var(--red)" : "var(--text3)" }}>{overdue}</div><div className="stat-label">Overdue</div></div>
      </div>

      <div className="kanban">
        {COLS.map(col => {
          const tasks = tasksByStatus(col.id);
          return (
            <div key={col.id} className={`k-col ${dragOver === col.id ? "drag-over" : ""}`}
              onDragOver={e => { e.preventDefault(); setDragOver(col.id); }}
              onDragLeave={() => setDragOver(null)}
              onDrop={() => { if (dragging && dragging !== col.id) dispatch({ type: "MOVE_TASK", id: dragging, status: col.id }); setDragging(null); setDragOver(null); }}>
              <div className="k-col-hd">
                <div className="k-col-title"><span className={`k-col-dot ${col.dot}`} />{col.label}</div>
                <div className="k-col-count">{tasks.length}</div>
