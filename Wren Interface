/* ─── REDUCER ────────────────────────────────────────────────────────────── */
const uid = () => Math.random().toString(36).slice(2, 10);

function reducer(state, action) {
  const ts = now();
  switch (action.type) {
    case "MOVE_TASK": {
      const { id, status } = action;
      const task = state.tasks.find(t => t._id === id);
      if (!task || task.status === status) return state;
      const event = { _id: uid(), workspaceId: WS_ID, entityType: "task", entityId: id, eventType: "task_status_changed", payload: { from: task.status, to: status }, createdAt: ts };
      return { ...state, tasks: state.tasks.map(t => t._id === id ? { ...t, status, updatedAt: ts } : t), activityEvents: [event, ...state.activityEvents] };
    }
    case "CREATE_TASK": {
      const task = { _id: uid(), workspaceId: WS_ID, ...action.payload, createdAt: ts, updatedAt: ts };
      const event = { _id: uid(), workspaceId: WS_ID, entityType: "task", entityId: task._id, eventType: "task_created", payload: { source: task.source }, createdAt: ts };
      return { ...state, tasks: [...state.tasks, task], activityEvents: [event, ...state.activityEvents] };
    }
    case "UPDATE_TASK": {
      const event = { _id: uid(), workspaceId: WS_ID, entityType: "task", entityId: action.id, eventType: "task_updated", payload: {}, createdAt: ts };
      return { ...state, tasks: state.tasks.map(t => t._id === action.id ? { ...t, ...action.payload, updatedAt: ts } : t), activityEvents: [event, ...state.activityEvents] };
    }
    case "DELETE_TASK":
      return { ...state, tasks: state.tasks.filter(t => t._id !== action.id) };
    case "CREATE_PROJECT": {
      const project = { _id: uid(), workspaceId: WS_ID, ...action.payload, createdAt: ts, updatedAt: ts };
      const event = { _id: uid(), workspaceId: WS_ID, entityType: "project", entityId: project._id, eventType: "project_created", payload: {}, createdAt: ts };
      return { ...state, projects: [...state.projects, project], activityEvents: [event, ...state.activityEvents] };
    }
    case "CREATE_CONTENT": {
      const item = { _id: uid(), workspaceId: WS_ID, ...action.payload, createdAt: ts, updatedAt: ts };
      const event = { _id: uid(), workspaceId: WS_ID, entityType: "content", entityId: item._id, eventType: "content_created", payload: { platform: item.platform }, createdAt: ts };
      return { ...state, contentItems: [...state.contentItems, item], activityEvents: [event, ...state.activityEvents] };
    }
    case "UPDATE_CONTENT": {
      return { ...state, contentItems: state.contentItems.map(c => c._id === action.id ? { ...c, ...action.payload, updatedAt: ts } : c) };
    }
    case "CREATE_DOCUMENT": {
      const doc = { _id: uid(), workspaceId: WS_ID, ...action.payload, createdAt: ts, updatedAt: ts };
      const event = { _id: uid(), workspaceId: WS_ID, entityType: "document", entityId: doc._id, eventType: "document_created", payload: {}, createdAt: ts };
      return { ...state, documents: [...state.documents, doc], activityEvents: [event, ...state.activityEvents] };
    }
    default: return state;
  }
}

/* ─── ACTIVITY SUMMARY ───────────────────────────────────────────────────── */
function summarizeEvent(event, state) {
  const { eventType, entityType, payload, entityId } = event;
  const task = state.tasks.find(t => t._id === entityId);
  const project = state.projects.find(p => p._id === entityId);
  const content = state.contentItems.find(c => c._id === entityId);
  const name = task?.title || project?.name || content?.title || entityId;
  const short = name?.length > 40 ? name.slice(0, 40) + "…" : name;
  switch (eventType) {
    case "task_status_changed": return <span>Task <strong>"{short}"</strong> moved from <span className={`badge badge-${payload.from}`}>{payload.from.replace("_", " ")}</span> to <span className={`badge badge-${payload.to}`}>{payload.to.replace("_", " ")}</span></span>;
    case "task_created": return <span>Task <strong>"{short}"</strong> created via <span className={`badge badge-${payload.source}`}>{payload.source}</span></span>;
    case "task_updated": return <span>Task <strong>"{short}"</strong> was updated</span>;
    case "project_created": return <span>Project <strong>"{short}"</strong> created</span>;
    case "content_created": return <span>Content idea <strong>"{short}"</strong> added for <span className="badge badge-tag">{payload.platform}</span></span>;
    case "document_created": return <span>Document <strong>"{short}"</strong> added</span>;
    default: return <span>{eventType} on {entityType}</span>;
  }
}

/* ─── TAG INPUT ──────────────────────────────────────────────────────────── */
function TagInput({ value = [], onChange }) {
  const [input, setInput] = useState("");
  const addTag = (tag) => { const t = tag.trim().toLowerCase(); if (t && !value.includes(t)) onChange([...value, t]); setInput(""); };
  return (
    <div className="tag-input-wrap" onClick={e => e.currentTarget.querySelector("input")?.focus()}>
      {value.map(t => (
        <span key={t} className="tag-pill">{t}<button onClick={() => onChange(value.filter(x => x !== t))}>×</button></span>
      ))}
      <input className="tag-input" placeholder="Add tag…" value={input}
        onChange={e => setInput(e.target.value)}
        onKeyDown={e => { if (e.key === "Enter" || e.key === ",") { e.preventDefault(); addTag(input); } if (e.key === "Backspace" && !input && value.length) onChange(value.slice(0, -1)); }} />
    </div>
  );
}

